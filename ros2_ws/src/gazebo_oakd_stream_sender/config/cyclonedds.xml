<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cyclonedds.org/schema/cyclonedds">
    <Domain id="any">
        <General>
            <Interfaces>
                <!-- Usually eno1 or similar on desktop, 'any' is safe if only one active -->
                <NetworkInterface name="any"/>
            </Interfaces>
            <AllowMulticast>default</AllowMulticast>
            <MaxMessageSize>10MB</MaxMessageSize>
            <FragmentSize>1344</FragmentSize>
        </General>
        <Discovery>
            <Peers>
                <!-- The Orange Pi Ethernet IP -->
                <Peer address="10.10.12.9"/>
            </Peers>
        </Discovery>
        <Internal>
            <MinimumSocketReceiveBufferSize>10MB</MinimumSocketReceiveBufferSize>
            <SocketReceiveBufferSize>10MB</SocketReceiveBufferSize>
        </Internal>
    </Domain>
</CycloneDDS>
