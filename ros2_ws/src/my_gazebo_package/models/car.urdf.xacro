<?xml version="1.0"?>
<robot name="ackermann_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find my_gazebo_package)/models/oakd_camera.urdf.xacro" />
    <xacro:oakd_camera parent_link="chassis" x="0.85" y="0" z="0.46" />

    <material name="blue">
        <color rgba="0.5 0.5 1.0 1"/>
    </material>
    <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
    </material>
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <link name="base_link"/>

    <joint name="base_link_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
            <geometry>
                <box size="2.01142 1 0.568726"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
            <geometry>
                <box size="2.01142 1 0.568726"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
            <mass value="1.14395"/>
            <inertia ixx="0.126164" ixy="0" ixz="0" iyy="0.416519" iyz="0" izz="0.481014"/>
        </inertial>
    </link>

    <!-- Steering Links -->
    <link name="front_left_wheel_steering_link">
        <visual>
            <geometry>
                <cylinder length="0.1" radius="0.03"/>
            </geometry>
            <material name="white"/>
        </visual>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
        </inertial>
    </link>

    <joint name="front_left_wheel_steering_joint" type="revolute">
        <parent link="chassis"/>
        <child link="front_left_wheel_steering_link"/>
        <origin xyz="0.554283 0.5 0.02" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.6" upper="0.6" velocity="1.0" effort="25"/>
    </joint>

    <link name="front_right_wheel_steering_link">
        <visual>
            <geometry>
                <cylinder length="0.1" radius="0.03"/>
            </geometry>
            <material name="white"/>
        </visual>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
        </inertial>
    </link>

    <joint name="front_right_wheel_steering_joint" type="revolute">
        <parent link="chassis"/>
        <child link="front_right_wheel_steering_link"/>
        <origin xyz="0.554283 -0.5 0.02" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.6" upper="0.6" velocity="1.0" effort="25"/>
    </joint>

    <!-- Wheels Macro -->
    <xacro:macro name="wheel" params="name parent_link *origin">
        <link name="${name}">
            <visual>
                <origin xyz="0 0 0" rpy="1.570796 0 0"/>
                <geometry>
                    <cylinder length="0.15" radius="0.3"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="1.570796 0 0"/>
                <geometry>
                    <cylinder length="0.15" radius="0.3"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 0" rpy="1.570796 0 0"/>
                <mass value="2"/>
                <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
            </inertial>
        </link>
        <joint name="${name}_joint" type="continuous">
            <parent link="${parent_link}"/>
            <child link="${name}"/>
            <xacro:insert_block name="origin"/>
            <axis xyz="0 1 0"/>
        </joint>
    </xacro:macro>

    <xacro:wheel name="front_left_wheel" parent_link="front_left_wheel_steering_link">
        <origin xyz="0 0.125029 -0.045" rpy="0 0 0"/>
    </xacro:wheel>

    <xacro:wheel name="front_right_wheel" parent_link="front_right_wheel_steering_link">
        <origin xyz="0 -0.125029 -0.045" rpy="0 0 0"/>
    </xacro:wheel>

    <xacro:wheel name="rear_left_wheel" parent_link="chassis">
        <origin xyz="-0.957138 0.625029 -0.025" rpy="0 0 0"/>
    </xacro:wheel>

    <xacro:wheel name="rear_right_wheel" parent_link="chassis">
        <origin xyz="-0.957138 -0.625029 -0.025" rpy="0 0 0"/>
    </xacro:wheel>

    <gazebo>
        <plugin
            filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
            <left_joint>front_left_wheel_joint</left_joint>
            <left_joint>rear_left_wheel_joint</left_joint>
            <right_joint>front_right_wheel_joint</right_joint>
            <right_joint>rear_right_wheel_joint</right_joint>
            <left_steering_joint>front_left_wheel_steering_joint</left_steering_joint>
            <right_steering_joint>front_right_wheel_steering_joint</right_steering_joint>
            <kingpin_width>1.0</kingpin_width>
            <steering_limit>0.5</steering_limit>
            <wheel_base>1.0</wheel_base>
            <wheel_separation>1.25</wheel_separation>
            <wheel_radius>0.3</wheel_radius>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <min_velocity>-1</min_velocity>
            <max_velocity>1</max_velocity>
            <min_acceleration>-3</min_acceleration>
            <max_acceleration>3</max_acceleration>
        </plugin>

        <plugin
            filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
        </plugin>
    </gazebo>

</robot>
