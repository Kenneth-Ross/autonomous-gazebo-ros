<?xml version="1.0"?>
<robot name="ackermann_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find my_gazebo_package)/models/oakd_camera.urdf.xacro" />
    <xacro:oakd_camera parent_link="chassis" x="0.85" y="0" z="0.46" />

    <material name="blue">
        <color rgba="0.5 0.5 1.0 1"/>
    </material>
    <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
    </material>
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <link name="base_link"/>

    <joint name="base_link_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
            <geometry>
                <box size="2.01142 1 0.568726"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
            <geometry>
                <box size="2.01142 1 0.568726"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
            <mass value="50.0"/>
            <inertia ixx="5.0" ixy="0" ixz="0" iyy="17.0" iyz="0" izz="20.0"/>
        </inertial>
    </link>

    <!-- IMU Link and Sensor -->
    <link name="imu_link">
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="chassis"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <update_rate>100</update_rate>
            <visualize>true</visualize>
            <topic>imu</topic>
            <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu">
            </plugin>
        </sensor>
    </gazebo>

    <!-- Steering Links -->
    <link name="front_left_wheel_steering_link">
        <visual>
            <geometry>
                <cylinder length="0.1" radius="0.03"/>
            </geometry>
            <material name="white"/>
        </visual>
        <inertial>
            <mass value="5.0"/>
            <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
        </inertial>
    </link>

    <joint name="front_left_wheel_steering_joint" type="revolute">
        <parent link="chassis"/>
        <child link="front_left_wheel_steering_link"/>
        <origin xyz="0.554283 0.5 0.02" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.6" upper="0.6" velocity="10.0" effort="1000"/>
    </joint>

    <link name="front_right_wheel_steering_link">
        <visual>
            <geometry>
                <cylinder length="0.1" radius="0.03"/>
            </geometry>
            <material name="white"/>
        </visual>
        <inertial>
            <mass value="5.0"/>
            <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
        </inertial>
    </link>

    <joint name="front_right_wheel_steering_joint" type="revolute">
        <parent link="chassis"/>
        <child link="front_right_wheel_steering_link"/>
        <origin xyz="0.554283 -0.5 0.02" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.6" upper="0.6" velocity="10.0" effort="1000"/>
    </joint>

    <!-- Wheels Macro -->
    <xacro:macro name="wheel" params="name parent_link *origin">
        <link name="${name}">
            <visual>
                <origin xyz="0 0 0" rpy="1.570796 0 0"/>
                <geometry>
                    <cylinder length="0.15" radius="0.3"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="1.570796 0 0"/>
                <geometry>
                    <cylinder length="0.15" radius="0.3"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 0" rpy="1.570796 0 0"/>
                <mass value="15.0"/>
                <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.7"/>
            </inertial>
        </link>
        <joint name="${name}_joint" type="continuous">
            <parent link="${parent_link}"/>
            <child link="${name}"/>
            <xacro:insert_block name="origin"/>
            <axis xyz="0 1 0"/>
            <limit effort="5000" velocity="100"/>
        </joint>
    </xacro:macro>

    <xacro:wheel name="front_left_wheel" parent_link="front_left_wheel_steering_link">
        <origin xyz="0 0.125029 -0.045" rpy="0 0 0"/>
    </xacro:wheel>

    <xacro:wheel name="front_right_wheel" parent_link="front_right_wheel_steering_link">
        <origin xyz="0 -0.125029 -0.045" rpy="0 0 0"/>
    </xacro:wheel>

    <xacro:wheel name="rear_left_wheel" parent_link="chassis">
        <origin xyz="-0.957138 0.625029 -0.025" rpy="0 0 0"/>
    </xacro:wheel>

    <xacro:wheel name="rear_right_wheel" parent_link="chassis">
        <origin xyz="-0.957138 -0.625029 -0.025" rpy="0 0 0"/>
    </xacro:wheel>

    <gazebo>
        <plugin
            filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
            <left_joint>front_left_wheel_joint</left_joint>
            <left_joint>rear_left_wheel_joint</left_joint>
            <right_joint>front_right_wheel_joint</right_joint>
            <right_joint>rear_right_wheel_joint</right_joint>
            <left_steering_joint>front_left_wheel_steering_joint</left_steering_joint>
            <right_steering_joint>front_right_wheel_steering_joint</right_steering_joint>
            <kingpin_width>1.0</kingpin_width>
            <steering_limit>0.5</steering_limit>
            <wheel_base>1.0</wheel_base>
            <wheel_separation>1.25</wheel_separation>
            <wheel_radius>0.3</wheel_radius>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_link</child_frame_id>
            <odom_publish_tf>false</odom_publish_tf>
            <min_velocity>-13.41</min_velocity>
            <max_velocity>13.41</max_velocity>
            <min_acceleration>-30</min_acceleration>
            <max_acceleration>30</max_acceleration>
        </plugin>

        <plugin
            filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
        </plugin>

        <plugin
            filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
            <publish_link_pose>false</publish_link_pose>
            <publish_sensor_pose>false</publish_sensor_pose>
            <publish_collision_pose>false</publish_collision_pose>
            <publish_visual_pose>false</publish_visual_pose>
            <publish_nested_model_pose>false</publish_nested_model_pose>
            <publish_model_pose>true</publish_model_pose>
            <use_pose_vector_msg>false</use_pose_vector_msg>
            <static_publisher>true</static_publisher>
            <static_update_frequency>30</static_update_frequency>
        </plugin>
    </gazebo>

</robot>
