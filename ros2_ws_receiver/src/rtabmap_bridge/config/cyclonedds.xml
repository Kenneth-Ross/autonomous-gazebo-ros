<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cyclonedds.org/schema/cyclonedds">
    <Domain id="any">
        <General>
            <Interfaces>
                <!-- Default to wlan0 as the primary link -->
                <NetworkInterface name="wlan0"/>
            </Interfaces>
            <AllowMulticast>default</AllowMulticast>
            <MaxMessageSize>10MB</MaxMessageSize>
            <FragmentSize>1344</FragmentSize>
        </General>
        <Internal>
            <MinimumSocketReceiveBufferSize>10MB</MinimumSocketReceiveBufferSize>
            <SocketReceiveBufferSize>10MB</SocketReceiveBufferSize>
        </Internal>
        <Tracing>
            <Verbosity>info</Verbosity>
            <OutputFile>stdout</OutputFile>
        </Tracing>
    </Domain>
</CycloneDDS>
