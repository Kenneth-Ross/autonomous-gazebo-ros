<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
    <Domain id="any">
        <General>
            <Interfaces>
                <!-- Binding to 'any' is safer on the Pi as interfaces can rename (enP4p65s0 vs eth0) -->
                <NetworkInterface name="any"/>
            </Interfaces>
            <MaxMessageSize>12MB</MaxMessageSize>
            <FragmentSize>1344B</FragmentSize>
            <AllowMulticast>spdp</AllowMulticast>
        </General>
        <Internal>
            <SocketReceiveBufferSize min="10MB"/>
        </Internal>
        <Discovery>
            <Peers>
                <!-- Add the Desktop Ethernet IP for direct discovery -->
                <Peer address="10.10.12.10"/>
            </Peers>
            <ParticipantIndex>auto</ParticipantIndex>
        </Discovery>
    </Domain>
</CycloneDDS>
